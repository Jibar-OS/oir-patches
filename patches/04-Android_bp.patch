+// OIR v0.1: internal worker AIDL consumed by system/oird as cpp and by
+// services/core (OIRService) as java. Internal + single-owner, so unstable
+// (no API-version tracking) — A16 requires this or we'd get -V1-cpp names.
+aidl_interface {
+    name: "oir_worker_aidl",
+    unstable: true,
+    local_include_dir: "java",
+    srcs: [
+        "java/com/android/server/oir/IOirWorker.aidl",
+        "java/com/android/server/oir/IOirWorkerCallback.aidl",
+        "java/com/android/server/oir/IOirWorkerVectorCallback.aidl",
+        "java/com/android/server/oir/IOirWorkerAudioCallback.aidl",
